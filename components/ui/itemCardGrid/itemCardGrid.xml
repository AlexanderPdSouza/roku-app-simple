<?xml version="1.0" encoding="utf-8"?>

<component name="itemCardGrid" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="showcontent" />
        <field id="focusPercent" type="float" onChange="showfocus" />
    </interface>
    <children>
        <Poster id="itemPoster" translation="[10,10]" width="288" height="288"
            scaleRotateCenter="[144,144]" />
        <Label id="itemLabel" translation="[0,310]" width="308" horizAlign="center" />
    </children>
    <script type="text/brightscript" uri="itemCardGrid.brs" />
</component>